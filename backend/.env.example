# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database. Leave DATABASE_URL empty to use SQLite (db.sqlite3).
# Example Postgres: postgres://user:password@localhost:5432/price_tracker
DATABASE_URL=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Celery / Redis (optional, only needed if you use Celery instead of management commands)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Scraper tuning
SCRAPER_TIMEOUT_SECONDS=20
SCRAPER_MAX_RETRIES=3
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; PriceTrackerBot/1.0)
SCRAPER_CONCURRENCY=4
